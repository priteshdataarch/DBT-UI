# Copy this file to .env.local and fill in your values

# OpenAI API Key - required for the AI chat assistant
OPENAI_API_KEY=sk-...

# AWS credentials - required for dbt run / dbt test (Athena connection)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-west-2

# Path to your dbt project root (defaults to the parent of dbt-ui/)
# DBT_PROJECT_ROOT=/Users/your-name/path/to/dbt_athena

# Path to dbt binary (defaults to vdbt/bin/dbt inside the project root)
# DBT_BIN=/Users/your-name/path/to/dbt_athena/vdbt/bin/dbt
